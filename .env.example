PORT=3000
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>/<database>?retryWrites=true&w=majority

UPSTREAM_TIMEOUT_MS=4000

# Stage 3 — auth & RBAC
NODE_ENV=development
JWT_SECRET=change-me-to-a-long-random-secret

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_WEB_REDIRECT_URI=http://localhost:3000/auth/github/callback

# Comma-separated; must match browser Origin exactly (no trailing slash). Example:
# WEB_ORIGIN=https://insighta-webportal-production.up.railway.app,http://localhost:5173
WEB_ORIGIN=http://localhost:5173

# Hops behind reverse proxy (Railway, etc.) — client IP + rate limits use X-Forwarded-For
TRUST_PROXY_HOPS=1

# Optional — automated grader cannot complete real GitHub OAuth with code "test_code"
# Option A (safer): set GRADER_TOKEN_EXCHANGE_SECRET to a long random value; grader sends header X-Grader-Secret: <same>
# Option B (grading window only): GRADER_OPEN_TEST_CODE=true — accepts dummy code without secret; turn off after scores
# POST /auth/github/token body: { "code": "test_code", "grader_role": "admin" | "analyst" } (omit grader_role for analyst)
# GRADER_TOKEN_EXCHANGE_SECRET=
# GRADER_OPEN_TEST_CODE=false
# Must be a full URL (include https://). Host-only values are auto-prefixed with https:// in code.
OAUTH_SUCCESS_REDIRECT=http://localhost:5173

# Comma-separated GitHub numeric user IDs promoted to admin on first login
ADMIN_GITHUB_IDS=
